function formatTime(seconds) {
  const m = Math.floor(seconds / 60).toString().padStart(2, '0')
  const s = (seconds % 60).toString().padStart(2, '0')
  return `${m}:${s}`
}

function ResultModal({ isOpen, stats, words, onRestart, onHome }) {
  if (!isOpen) return null

  return (
    <div className="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center">
      <div className="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4">
        <h2 className="text-3xl font-bold text-center mb-6">🎉 章节完成！</h2>

        <div className="grid grid-cols-2 gap-4 mb-6">
          <div className="bg-gray-50 rounded-lg p-4 text-center">
            <div className="text-xs text-gray-500 uppercase">用时</div>
            <div className="text-2xl font-bold text-indigo-600 mt-1">{formatTime(stats.elapsed)}</div>
          </div>
          <div className="bg-gray-50 rounded-lg p-4 text-center">
            <div className="text-xs text-gray-500 uppercase">正确率</div>
            <div className="text-2xl font-bold text-indigo-600 mt-1">{stats.accuracy}%</div>
          </div>
          <div className="bg-gray-50 rounded-lg p-4 text-center">
            <div className="text-xs text-gray-500 uppercase">WPM</div>
            <div className="text-2xl font-bold text-indigo-600 mt-1">{stats.wpm}</div>
          </div>
          <div className="bg-gray-50 rounded-lg p-4 text-center">
            <div className="text-xs text-gray-500 uppercase">正确数/总数</div>
            <div className="text-2xl font-bold text-indigo-600 mt-1">
              {stats.correctCount}/{words.length}
            </div>
          </div>
        </div>

        <div className="flex flex-col items-center gap-3">
          <button
            onClick={onRestart}
            className="bg-indigo-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-indigo-700 transition-colors w-full"
          >
            再来一次
          </button>
          <button
            onClick={onHome}
            className="text-indigo-600 underline text-sm"
          >
            返回首页
          </button>
        </div>
      </div>
    </div>
  )
}

export default ResultModal
