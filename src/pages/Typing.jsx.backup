import { useState, useEffect, useRef } from 'react'
import { useParams, useNavigate } from 'react-router-dom'
import { useTyping } from '../hooks/useTyping'
import { getChapter } from '../data/index.js'
import StatsPanel from '../components/StatsPanel'
import ResultModal from '../components/ResultModal'

function Typing() {
  const { dictId, chapterId } = useParams()
  const navigate = useNavigate()
  const [words, setWords] = useState([])
  const containerRef = useRef(null)

  useEffect(() => {
    const chapter = getChapter(dictId, chapterId)
    if (chapter?.words) {
      setWords(chapter.words)
    }
  }, [dictId, chapterId])

  const typing = useTyping(words)

  // 点击遮罩启动
  const handleStart = async () => {
    if (!typing.started) {
      await typing.start()
    }
  }

  useEffect(() => {
    if (containerRef.current) {
      containerRef.current.focus()
    }
  }, [])

  if (!words || words.length === 0) {
    return <div className="text-center mt-20 text-gray-400">加载中...</div>
  }

  const currentWord = typing.currentWord
  const letterProgress = currentWord ? typing.userInput.length / currentWord.word.length : 0
  const progress = (typing.currentIndex + letterProgress) / words.length

  return (
    <div
      ref={containerRef}
      className="relative select-none outline-none"
      onClick={handleStart}
      tabIndex={0}
      autoFocus
    >
      {/* 顶部进度条 */}
      <div className="fixed top-0 left-0 right-0 h-1.5 bg-gray-200 z-40">
        <div className="bg-indigo-500 h-full transition-all duration-500" style={{ width: `${progress * 100}%` }} />
      </div>

      {/* 启动遮罩 */}
      {!typing.started && !typing.isFinished && (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-white/90 backdrop-blur-sm cursor-pointer">
          <div className="text-center animate-pulse">
            <p className="text-3xl font-bold text-gray-800 mb-3">点击屏幕或按任意键开始</p>
            <p className="text-sm text-gray-500">首次交互将解锁音频权限</p>
          </div>
        </div>
      )}

      {/* 中央区域 */}
      <div className="flex-1 flex flex-col items-center justify-center min-h-screen pt-20 pb-32 px-6">
        <p className="text-sm text-gray-400 mb-6">第 {typing.currentIndex + 1} / {words.length}</p>

        {currentWord && (
          <>
            <div className={`text-5xl sm:text-6xl font-bold tracking-widest ${typing.isError ? 'animate-shake text-red-500' : 'text-gray-800'}`}>
              {currentWord.word.split('').map((char, index) => (
                <span key={index} className={index < typing.userInput.length ? 'text-indigo-600' : 'text-gray-300'}>
                  {char}
                </span>
              ))}
            </div>

            <p className="text-lg text-gray-400 font-mono mt-6">{currentWord.phonetic}</p>
            <p className="text-xl text-gray-600 mt-3">{currentWord.translation}</p>

            <div className="mt-8 flex gap-4 items-center">
              <button onClick={(e) => { e.stopPropagation(); typing.speak(currentWord.word) }} className="p-2 rounded-full hover:bg-gray-100 transition-colors" title="朗读">
                <svg xmlns="http://www.w3.org/2000/svg" className="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                  <path strokeLinecap="round" strokeLinejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                </svg>
              </button>
              <button onClick={(e) => { e.stopPropagation(); typing.toggleSound() }} className="p-2 rounded-full hover:bg-gray-100 transition-colors text-xl" title={typing.soundEnabled ? '关闭声音' : '开启声音'}>
                {typing.soundEnabled ? '🔊' : '🔇'}
              </button>
            </div>
          </>
        )}
      </div>

      <StatsPanel stats={typing.stats} />

      <ResultModal
        isOpen={typing.isFinished}
        stats={typing.stats}
        words={words}
        onRestart={() => { typing.handleRestart() }}
        onHome={() => navigate('/')}
      />
    </div>
  )
}

export default Typing
