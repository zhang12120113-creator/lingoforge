import { useParams, useNavigate } from 'react-router-dom'
import { getDictionary } from '../data/index.js'

function ChapterSelect() {
  const { dictId } = useParams()
  const navigate = useNavigate()
  const dict = getDictionary(dictId)

  if (!dict) {
    return (
      <div className="max-w-4xl mx-auto px-6 py-10 text-center">
        <p className="text-xl text-gray-600">词库不存在</p>
        <button
          onClick={() => navigate('/')}
          className="mt-6 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors"
        >
          返回词库列表
        </button>
      </div>
    )
  }

  return (
    <div className="max-w-4xl mx-auto px-6 py-10">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-gray-800">{dict.name}</h1>
        <p className="text-gray-500 mt-2">{dict.description}</p>
        <button
          onClick={() => navigate('/')}
          className="mt-4 px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors"
        >
          返回词库列表
        </button>
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {dict.chapters.map((chapter) => (
          <div
            key={chapter.id}
            onClick={() => navigate(`/typing/${dictId}/${chapter.id}`)}
            className="bg-white rounded-xl shadow p-5 cursor-pointer hover:shadow-md transition-shadow"
          >
            <h3 className="text-lg font-semibold text-gray-800">{chapter.name}</h3>
            <p className="text-sm text-gray-500 mt-1">{chapter.words.length} 词</p>
            <div className="mt-3 bg-gray-200 h-2 rounded-full overflow-hidden">
              <div className="w-0 bg-green-500 h-full" />
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}

export default ChapterSelect
